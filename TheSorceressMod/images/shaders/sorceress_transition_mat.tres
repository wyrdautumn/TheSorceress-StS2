[gd_resource type="ShaderMaterial" load_steps=3 format=3 uid="uid://b5407kw7n3r31"]

[ext_resource type="Texture2D" uid="uid://danafuwmkhovc" path="res://TheSorceressMod/images/shaders/sorceress_transition.png" id="2_agy6v"]

[sub_resource type="Shader" id="Shader_3ab6h"]
code = "shader_type canvas_item;

uniform sampler2D transitionTex;
uniform float threshold : hint_range(0,1);

void fragment() {
    float falloff = 1.0 - texture(transitionTex, UV).r;
    
    // helps with falloff artifacts issues towards the transition extremes
    float remap  = mix(-0.1, 1.1, threshold);
    falloff = step(falloff, remap);
    COLOR.a = falloff;
}
"

[resource]
resource_local_to_scene = true
shader = SubResource("Shader_3ab6h")
shader_parameter/threshold = 0.0
shader_parameter/transitionTex = ExtResource("2_agy6v")
